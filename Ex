PROGRAM 04

-- Nested Query: 

1) Find employees who earn more than the average salary

SELECT Emp_Name, Salary FROM Employee
WHERE Salary > (SELECT AVG(Salary) FROM Employee);

2) Find Employees working in a specific department

SELECT Emp_Name
FROM Employee
WHERE Dept_ID IN (SELECT Dept_ID
                  FROM Department
                  WHERE Dept_Name = 'IT');

3) List employees whose department is NOT assigned

SELECT Emp_Name
FROM Employee
WHERE Dept_ID NOT IN (SELECT Dept_ID FROM Department);




--JOINS:

-- Inner Join: Display employee name and their department
SELECT E.Emp_Name, D.Dept_Name
FROM Employee E
JOIN Department D ON E.Dept_ID = D.Dept_ID;

-- Left Join: Display all departments with employees (if any)
SELECT D.Dept_Name, E.Emp_Name
FROM Department D
LEFT JOIN Employee E ON D.Dept_ID = E.Dept_ID;

----Right Join: Display ALL employees, along with their department names.
SELECT D.Dept_Name, E.Emp_Name
FROM Department D
RIGHT JOIN Employee E ON D.Dept_ID = E.Dept_ID;










