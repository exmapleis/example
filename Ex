PROGRAM 
CREATE OR REPLACE PROCEDURE arithmetic_ops(a IN NUMBER, b IN NUMBER)
IS
add_result NUMBER;
sub_result NUMBER;
mul_result NUMBER;
div_result NUMBER;
BEGIN
add_result := a + b;
sub_result := a - b;
mul_result := a * b;
IF b != 0 THEN
div_result := a / b;
ELSE
div_result := NULL;
END IF;
DBMS_OUTPUT.PUT_LINE('First Number :' || a);
DBMS_OUTPUT.PUT_LINE('Second Number :'|| b);
DBMS_OUTPUT.PUT_LINE('Addition : ' || add_result);
DBMS_OUTPUT.PUT_LINE('Subtraction : '|| sub_result);
DBMS_OUTPUT.PUT_LINE('Multiplication:'|| mul_result);
IF b != 0 THEN
DBMS_OUTPUT.PUT_LINE('Division : ' || div_result);
ELSE
DBMS_OUTPUT.PUT_LINE('Division : Cannot divide by zero');
END IF;
END;
/

Execution Command:
EXEC arithmetic_ops(10, 5);








